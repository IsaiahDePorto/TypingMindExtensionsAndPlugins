 properties: {\n              item: { type: 'STRING' },\n              sourceIds: { type: 'ARRAY', items: { type: 'INTEGER' } },\n              confidence: { type: 'STRING' }\n            },\n            required: ['item', 'sourceIds', 'confidence']\n          }\n        },\n        missing_facets: { type: 'ARRAY', items: { type: 'STRING' } }\n      },\n      required: ['preferred_action', 'required_caveat', 'confidence_ceiling', 'artifacts', 'structured_items', 'missing_facets']\n    };\n\n    const recoveryPrompt = `SCHEMA RECOVERY MODE. Output only the reduced schema. Preserve exact artifact text if available.\\\\\\n${ucsPrompt}`;\n    const recoveryText = await callGemini(ucsSystem, recoveryPrompt, recoverySchema, 3072);\n    try {\n      const recovered = JSON.parse(runHRP(recoveryText));\n      if (recovered && typeof recovered.preferred_action === 'string') {\n        finalPayload = {\n          epistemic_tension: branchMissingAxes.length > 0 || citationGraph.circular_chains.length > 0 || citationGraph.single_primary !== null,\n          preferred_action: recovered.preferred_action,\n          required_caveat: recovered.required_caveat,\n          actionability_limit: branchMissingAxes.length ? 'Evidence coverage is incomplete; avoid overclaiming beyond the extracted material.' : '',\n          confidence_ceiling: recovered.confidence_ceiling || 'Medium',\n          artifacts: toArray(recovered.artifacts),\n          structured_items: toArray(recovered.structured_items),\n          claims: [],\n          missing_facets: unique([...(recovered.missing_facets || []), ...branchMissingAxes])\n        };\n      }\n    } catch (e) {\n      // degrade below\n    }\n  }\n\n  if (!finalPayload) {\n    return {\n      completion_state: 'degraded',\n      transport_state: transportState,\n      failed_stage: 'reconciliation_parsing_error',\n      retrieval_state: {\n        search_mode: routePlan.search_mode,\n        branch_statuses: branchStatuses,\n        missing_axe