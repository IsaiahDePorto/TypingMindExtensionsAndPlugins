denceLattice = [];\n  const branchMissingAxes = [];\n  if (routePlan.search_mode === 'dual') {\n    if (!sourceObjects.some(s => s.branch === 'primary')) branchMissingAxes.push('supporting_evidence_under_sampled');\n    if (!sourceObjects.some(s => s.branch === 'adversarial')) branchMissingAxes.push('counterevidence_under_sampled');\n  }\n\n  const sourcesByBranch = {\n    primary: sourceObjects.filter(s => s.branch === 'primary'),\n    adversarial: sourceObjects.filter(s => s.branch === 'adversarial')\n  };\n\n  ['primary', 'adversarial'].forEach(branch => {\n    const branchSources = sourcesByBranch[branch] || [];\n    if (branchSources.length === 0) return;\n    const branchBudget = branch === 'primary' ? perBranchBudget.primary : perBranchBudget.adversarial;\n    const perSourceBudget = clamp(Math.floor(branchBudget / branchSources.length), routePlan.need_class === 'fact_pin' ? 1200 : 2000, routePlan.need_class === 'code_extract' || routePlan.need_class === 'forum_troubleshoot' ? 7000 : 5500);\n    branchSources.forEach(source => {\n      const windows = selectWindowsForSource(source, routePlan, perSourceBudget);\n      windows.forEach(w => evidenceLattice.push(w));\n    });\n  });\n\n  if (evidenceLattice.length === 0) {\n    sourceObjects.forEach(source => {\n      evidenceLattice.push({ sourceId: source.id, kind: 'support', text: truncate(source.text || '', 3000) });\n    });\n  }\n\n  const ucsSystem = `TEMPORAL GROUNDING MANDATE: Today is ${today}. Current year is ${currentYear}. You are operating in real time.\\nYou are the Unified Context Sieve for Exa-ELDG Hybrid v7.5. The parent model needs complete, granular data coverage and a precise meta-analytical assessment of the gathered material.\\n\\nHIGH-FIDELITY CONDUIT & META-EVALUATION MANDATES:\\n- NEVER suggest that the user or parent model \"refer to the official website,\" \"check the documentation,\" or \"manually lookup\" info themselves. You are the retriever.\\n- TRANSMIT, DON'T CONCLUDE: Focus strictly on passing along the exact, granular information found in the evidence lattice. Do not synthesize speculative high-level trends, draw narrative conclusions, or smooth over omissions. Let the parent model draw the final thematic conclusions.\\n- NATURE OF THE INFORMATION ASSESSMENT: Shift your focus from synthesizing conclusions to evaluating the *completeness and nature* of the retrieved data itself. If information is missing, incomplete, ambiguous, or contradictory, highlight this explicitly as a primary meta-finding.\\n- DATA GAPS & EMPTY DATASETS: If the exact primary source data, tables, or parameters are missing, do NOT construct \"representative\" estimates. Instead, compile exactly what *is* there, clearly list what is missing in 'missing_facets', and document these limitations in 'actionability_limit' or 'required_caveat'.\\n\\nRETRIEVAL POLICY:\\n1. Use the Control Layer for robust, objective analytical guidance on the reliability and gaps of the dataset.\\n2. If the query is historical or quantitative, compile the specific numbers, percentages, or milestones from the evidence lattice item-by-item. If data points for certain years are absent, preserve that gap and list the missing years under 'missing_facets'.\\n3. Copy exact, raw verbatim spans carefully into artifacts if requested, ensuring absolute fidelity to the source without editorial clean-up.\\n4. Keep claims strictly grounded, noting exactly which source provided which assertion, and explicitly rate confidence based on the presence of direct evidence (rather than inference).\\n\\nCREDIBILITY-WEIGHTED EXTRACTION DIRECTIVES (v7.5):\\n- Every source now carries a SIFT source passport containing an overall_epistemic_weight (0.0 to 1.0) and an auditorial_advisory_for_parent_llm.\\n- Prioritize extraction from sources with higher overall_epistemic_weight.\\n- Treat sources with overall_epistemic_weight < 0.4 with intense skepticism. Discard their speculative framing, alarmist or emotional vocabula