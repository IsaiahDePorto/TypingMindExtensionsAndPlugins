      "code": "async function exa_eldg(params, userSettings) {\n  const { query, contextMetadata, outputIntent, detailMode } = params;\n  const proxyBase = (userSettings.proxyUrl || 'https://unified-proxy.creativeappmaking.workers.dev').replace(/\\/$/, '');\n  const geminiApiKey = userSettings.google_api_key;\n  const exaApiKey = userSettings.exa_api_key;\n  const geminiProxyUrl = `${proxyBase}/proxy/https://generativelanguage.googleapis.com/v1beta/interactions`;\n  const geminiDirectUrl = 'https://generativelanguage.googleapis.com/v1beta/interactions';\n  const exaProxyUrl = `${proxyBase}/exa/search`;\n  const exaDirectUrl = 'https://api.exa.ai/search';\n  const today = new Date().toISOString().split('T')[0];\n  const currentYear = today.split('-')[0];\n  let transportState = 'healthy';\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  function clamp(num, min, max) {\n    return Math.max(min, Math.min(max, num));\n  }\n\n  function unique(arr) {\n    return Array.from(new Set((arr || []).filter(Boolean)));\n  }\n\n  function toArray(v) {\n    return Array.isArray(v) ? v.filter(Boolean) : [];\n  }\n\n  function truncate(text, max) {\n    if (!text) return '';\n    return text.length <= max ? text : text.slice(0, max);\n  }\n\n  function normalizeUrl(url) {\n    try {\n      const u = new URL(url);\n      u.hash = '';\n      u.search = '';\n      return u.toString().replace(/\\/\\/$/, '/').replace(/\\/$/, '');\n    } catch (e) {\n      return url || '';\n    }\n  }\n\n  function safeDomain(url) {\n    try {\n      return new URL(url).hostname.replace(/^www\\./, '');\n    } catch (e) {\n      return 'unknown';\n    }\n  }\n\n  function cleanTextPreserveLines(text) {\n    if (!text) return '';\n    return String(text)\n      .replace(/\\r/g, '\\n')\n      .replace(/\\u0000/g, '')\n      .replace(/\\t/g, '  ')\n      .replace(/[ \\u00A0]+\\\\n/g, '\\n')\n      .replace(/\\n{3,}/g, '\\n\\n')\n      .trim();\n  }\n\n  function lineLooksCode(line) {\n    if (!line) return false;\n    const trimmed = line.trim();\n    if (!trimmed) return false;\n    if (/^(import |export |const |let |var |function |async function |class |interface |type |enum |SELECT |INSERT |UPDATE |DELETE |CREATE |ALTER |curl |npm |pnpm |yarn |docker |kubectl |terraform |resource |module |FROM |WHERE )/i.test(trimmed)) return true;\n    if (/=>|\\{\\s*$|^\\}|;\\s*$|<\\/?[A-Za-z]|Response\\.json|NextResponse|await |return |console\\.|\\\\s{2,}[A-Za-z0-9_$]/.test(line)) return true;\n    return false;\n  }\n\n  function lineLooksList(line) {\n    if (!line) return false;\n    const trimmed = line.trim();\n    return /^([-*\u2022]|[|]|_Private|\\d+[.)]|[A-Za-z]\\.)\\s+/.test(trimmed) || trimmed.startsWith('|');\n  }\n\n  function lineLooksLegal(line) {\n    if (!line) return false;\n    return /\\b(section|article|clause|statute|regulation|subsection|paragraph|shall|pursuant|effective date|whereas|hereby|means)\\b/i.test(line);\n  }\n\n  function extractTextFromInteraction(data) {\n    if (!data || !data.steps) return '';\n    let textParts = [];\n    for (const step of data.steps) {\n      if (step.type === 'model_output' && step.content) {\n        for (const block of step.content) {\n          if (block.type === 'text' && block.text) {\n            textParts.push(block.text);\n          }\n        }\n      }\n    }\n    return textParts.join('');\n  }\n\n  async function callGemini(systemInstruction, userPrompt, responseSchema, maxOutputTokens) {\n    const payload = {\n      model: 'gemini-3.5-flash-lite',\n      input: userPrompt,\n      system_instruction: systemInstruction\n    };\n\n    if (maxOutputTokens) {\n      payload.generation_config = {\n        max_output_tokens: maxOutputTokens\n      };\n    }\n\n    if (responseSchema) {\n      payload.response_format = {\n        type: 'text',\n        mime_type: 'application/json',\n        schema: responseSchema\n      };\n    }\n\n    const headers = {\n      'Content-Type': 'application/json',\n      'x-goog-api-key': geminiApiKey,\n      'Api-Revision': '2026-05-20'\n    };\n\n    const endpoints = [geminiProxyUrl, geminiDirectUrl];\n    for (const endpoint of endpoints) {\n      try {\n        const res = await fetch(endpoint, {\n          method: 'POST',\n          headers: headers,\n          body: JSON.stringify(payload)\n        });\n        if (res.ok) {\n          const data = await res.json();\n          return extractTextFromInteraction(data);\n        }\n      } catch (e) {\n        // Fall back to next endpoint\n      }\n    }\n    return null;\n  }\n\n  function tokenizeNeedles(routePlan) {\n    const terms = [];\n    terms.push(...toArray(routePlan.key_terms));\n    const depNames = Object.keys((contextMetadata && contextMetadata.dependencyManifest) || {});\n    terms.push(...depNames);\n    const q = String(query || '').split(/[^A-Za-z0-9_.#:-]+/).filter(t => t && t.length > 2);\n    terms.push(...q.slice(0, 16));\n    return unique(terms.map(t => String(t).trim()).filter(t => t.length > 1)).slice(0, 24);\n  }\n\n  function countKeywordHits(text, terms) {\n    if (!text) return 0;\n    const lower = text.toLowerCase();\n    let score = 0;\n    for (const term of terms) {\n      const t = String(term).toLowerCase();\n      if (!t) continue;\n      if (lower.includes(t)) score += Math.min(3, lower.split(t).length - 1);\n    }\n    return score;\n  }\n\n  function chunkText(text, targetSize) {\n    const cleaned = cleanTextPreserveLines(text);\n    if (!cleaned) return [];\n    const paragraphs = cleaned.split(/\\n\\s*\\n/).filter(Boolean);\n    if (paragraphs.length === 0) return [cleaned.slice(0, targetSize)];\n\n    const chunks = [];\n    let current = '';\n    for (const para of paragraphs) {\n      const isTableOrList = para.includes('|') || para.split('\\n').some(lineLooksList);\n      const candidate = current ? `${current}\\n\\n${para}` : para;\n      \n      if (isTableOrList && candidate.length <= targetSize * 1.5) {\n        current = candidate;\n      } else if (candidate.length <= targetSize) {\n        current = candidate;\n      } else {\n        if (current) chunks.push(current);\n        if (para.length <= targetSize) {\n          current = para;\n        } else {\n          for (let i = 0; i < para.length; i += targetSize) {\n            chunks.push(para.slice(i, i + targetSize));\n          }\n          current = '';\n        }\n      }\n    }\n    if (current) chunks.push(current);\n    return chunks;\n  }\n\n  function scoreChunk(chunk, routePlan, searchBranch) {\n    const terms = tokenizeNeedles(routePlan);\n    const lines = chunk.split('\\n');\n    const codeLines = lines.filter(lineLooksCode).length;\n    const listLines = lines.filter(lineLooksList).length;\n    const legalLines = lines.filter(lineLooksLegal).length;\n    const keywordHits = countKeywordHits(chunk, terms);\n    const lower = chunk.toLowerCase();\n    const boundaryHits = (lower.match(/\\b(but|except|unless|however|warning|caveat|limitation|issue|deprecated|broken|note|workaround|fix|hack|solved|solution|resolved)\\b/g) || []).length;\n    let score = keywordHits * 3 + boundaryHits * 2;\n\n    if (routePlan.need_class === 'code_extract') score += codeLines * 5 + listLines;\n    if (routePlan.need_class === 'forum_troubleshoot') score += (boundaryHits * 4) + (listLines * 2) + (codeLines * 2);\n    if (routePlan.need_class === 'enumeration_extract' || routePlan.need_class === 'procedure_extract') score += listLines * 4 + codeLines;\n    if (routePlan.need_class === 'verbatim_extract' || outputIntent === 'VERBATIM_STATUTE') score += legalLines * 4;\n    if (routePlan.need_class === 'version_pin' || routePlan.need_class === 'contradiction_audit') score += boundaryHits * 3;\n    if (searchBranch === 'adversarial') score += 1;\n    return score;\n  }\n\n  function selectWindowsForSource(source, routePlan, budgetChars) {\n    const targetChunk = routePlan.need_class === 'code_extract' ? 2400 : routePlan.breadth_mode === 'exhaustive' ? 3200 : 1800;\n    const chunks = chunkText(source.text || '', targetChunk);\n    if (chunks.length === 0) return [];\n\n    const scored = chunks.map((chunk, idx) => ({\n      idx,\n      text: chunk,\n      score: scoreChunk(chunk, routePlan, source.branch),\n      codeLines: chunk.split('\\n').filter(lineLooksCode).length,\n      listLines: chunk.split('\\n').filter(lineLooksList).length,\n      legalLines: chunk.split('\\n').filter(lineLooksLegal).length,\n    }));\n\n    scored.forEach(c => {\n      if (/disclaimer|disclosure|acknowledgement|funding|conflict of interest|declaration of interest|fictional|fictitious|made up|lying loser/i.test(c.text)) {\n        c.score += 1000;\n      }\n    });\n\n    scored.sort((a, b) => b.score - a.score || a.idx - b.idx);\n\n    const maxWindows = routePlan.breadth_mode === 'exhaustive' ? 6 : 4;\n    const chosen = [];\n    let spent = 0;\n    const usedIdx = new Set();\n\n    for (const candidate of scored) {\n      if (chosen.length >= maxWindows) break;\n      if (spent >= budgetChars) break;\n      if (usedIdx.has(candidate.idx)) continue;\n      const remaining = budgetChars - spent;\n      const pickedText = truncate(candidate.text, remaining);\n      if (!pickedText) continue;\n\n      let kind = 'context';\n      if (routePlan.need_class === 'code_extract' && candidate.codeLines >= 2) kind = 'code';\n      else if (routePlan.need_class === 'forum_troubleshoot' && (candidate.text.includes('workaround') || candidate.text.includes('fix') || candidate.text.includes('solved'))) kind = 'solution';\n      else if ((routePlan.need_class === 'enumeration_extract' || routePlan.need_class === 'procedure_extract') && candidate.listLines >= 2) kind = 'list';\n      else if ((routePlan.need_class === 'verbatim_extract' || outputIntent === 'VERBATIM_STATUTE') && candidate.legalLines >= 1) kind = 'verbatim';\n      else if ((source.branch === 'adversarial') || /\\b(but|except|unless|however|warning|caveat|limitation|issue|deprecated|broken|note)\\b/i.test(candidate.text)) kind = 'boundary';\n      else kind = 'support';\n\n      chosen.push({ sourceId: source.id, kind, text: pickedText });\n      usedIdx.add(candidate.idx);\n      spent += pickedText.length;\n    }\n\n    if (chosen.length === 0) {\n      chosen.push({ sourceId: source.id, kind: 'support', text: truncate(source.text || '', budgetChars) });\n    }\n\n    return chosen;\n  }\n\n  function classifySourceRole(url, title) {\n    const domain = safeDomain(url);\n    const titleLower = String(title || '').toLowerCase();\n    if (/github\\.com$/.test(domain)) return 'github';\n    if (/docs|developer|developers|reference|manual|api/.test(domain) || /documentation|reference|api/i.test(titleLower)) return 'official_docs';\n    if (/wikipedia\\.org$/.test(domain)) return 'encyclopedia';\n    if (/reddit\\.com$|stackoverflow\\.com$|stackexchange\\.com$|discord\\.com$|discourse|forums|community/.test(domain) || /forum|discussion|thread/i.test(titleLower)) return 'forum';\n    return 'web';\n  }\n\n  function classifySourceCredibility(url, title, text) {\n    const domain = safeDomain(url);\n    const urlLower = String(url || '').toLowerCase();\n    const titleLower = String(title || '').toLowerCase();\n    const textLower = String(text || '').toLowerCase();\n    \n    if (urlLower.includes('preprint') || titleLower.includes('preprint') || domain.includes('preprints.org') || textLower.includes('preprint server')) {\n      return { level: 2, label: 'Tertiary Source', rationale: 'Unreviewed academic preprint. Must be treated with extreme clinical skepticism.' };\n    }\n\n    const primarySuffixes = ['.gov', '.mil', '.gov.uk', '.europa.eu', '.senate.gov', '.house.gov'];\n    for (const suffix of primarySuffixes) {\n      if (domain === suffix.substring(1) || domain.endsWith(suffix)) {\n        return { level: 0, label: 'Primary Source', rationale: `Verified government domain: ${domain}` };\n      }\n    }\n    \n    const primaryDomains = [\n      'congress.gov', 'federalregister.gov', 'supremecourt.gov', 'pacer.uscourts.gov', \n      'legislation.gov.uk', 'data.gov', 'census.gov', 'bls.gov', 'fred.stlouisfed.org', \n      'data.worldbank.org', 'clinicaltrials.gov'\n    ];\n    if (primaryDomains.includes(domain)) {\n      return { level: 0, label: 'Primary Source', rationale: `Matches primary database: ${domain}` };\n    }\n    \n    if (/\\b10\\.\\d{4,}\\//.test(url) || urlLower.includes('doi.org/10.')) {\n      return { level: 0, label: 'Primary Source', rationale: 'Matches DOI publication pattern' };\n    }\n    \n    const academicDomains = ['arxiv.org', 'pubmed.ncbi.nlm.nih.gov', 'doi.org', 'sciencedirect.com', 'ieee.org', 'nature.com', 'springer.com', 'researchgate.net'];\n    if (academicDomains.includes(domain) || academicDomains.some(d => domain.endsWith('.' + d))) {\n      return { level: 0, label: 'Primary Source', rationale: `Peer-reviewed scientific repository: ${domain}` };\n    }\n    \n    if (domain === 'github.com' && urlLower.includes('/blob/')) {\n      return { level: 0, label: 'Primary Source', rationale: 'Matches raw code repository source file' };\n    }\n    \n    const eduSuffixes = ['.edu', '.ac.uk', '.edu.au', '.edu.cn', '.edu.sg', '.edu.hk'];\n    if (eduSuffixes.some(suffix => domain === suffix.substring(1) || domain.endsWith(suffix)) || domain.includes('.edu.')) {\n      return { level: 1, label: 'Secondary Source', rationale: `Academic or educational institution: ${domain}` };\n    }\n\n    if (/museum\\b|smithsonian|airandspace/i.test(domain) || /museum|smithsonian/i.test(titleLower)) {\n      return { level: 1, label: 'Secondary Source', rationale: `Museum or historical reference archive: ${domain}` };\n    }\n\n    const majorNewsDomains = [\n      'reuters.com', 'apnews.com', 'npr.org', 'bbc.com', 'bbc.co.uk', 'pbs.org', 'propublica.org',\n      'theguardian.com', 'nytimes.com', 'washingtonpost.com', 'wsj.com', 'politico.com',\n      'axios.com', 'vox.com', 'theatlantic.com', 'newyorker.com', 'economist.com'\n    ];\n    if (majorNewsDomains.some(outlet => domain === outlet || domain.endsWith('.' + outlet))) {\n      return { level: 1, label: 'Secondary Source', rationale: `Established editorial news outlet: ${domain}` };\n    }\n\n    const pressReleaseDomains = ['prnewswire.com', 'businesswire.com', 'globenewswire.com', 'eurekalert.org'];\n    if (pressReleaseDomains.includes(domain)) {\n      return { level: 1, label: 'Secondary Source', rationale: 'Press release distribution channel' };\n    }\n    \n    if (domain === 'wikipedia.org' || domain.endsWith('.wikipedia.org')) {\n      return { level: 1, label: 'Secondary Source', rationale: 'Wikipedia online encyclopedia' };\n    }\n    \n    const institutionalBlogs = ['theconversation.com', 'scholar.google.com'];\n    if (institutionalBlogs.some(blog => domain === blog || domain.endsWith('.' + blog))) {\n      return { level: 1, label: 'Secondary Source', rationale: 'Institutional research blog' };\n    }\n    \n    if (/\\b(analysis|explainer|opinion|commentary|review|roundup)\\b/i.test(titleLower)) {\n      return { level: 1, label: 'Secondary Source', rationale: 'Matches commentary/analysis pattern' };\n    }\n\n    const socialMediaDomains = ['reddit.com', 'twitter.com', 'x.com', 'facebook.com', 'medium.com', 'substack.com', 'youtube.com', 'tiktok.com'];\n    if (socialMediaDomains.some(sm => domain === sm || domain.endsWith('.' + sm))) {\n      return { level: 2, label: 'Tertiary Source', rationale: 'Social media or user-generated blog platform' };\n    }\n    \n    const aggregatorDomains = ['news.google.com', 'apple.news', 'flipboard.com', 'feedly.com', 'ground.news', 'allsides.com'];\n    if (aggregatorDomains.some(agg => domain === agg || domain.endsWith('.' + agg))) {\n      return { level: 2, label: 'Tertiary Source', rationale: 'News aggregator service' };\n    }\n    \n    const advocacyDomains = ['heritage.org', 'americanprogress.org', 'aei.org', 'brookings.edu', 'cfr.org'];\n    if (advocacyDomains.some(adv => domain === adv || domain.endsWith('.' + adv))) {\n      return { level: 2, label: 'Tertiary Source', rationale: 'Think-tank or advocacy organization' };\n    }\n    \n    const analystDomains = ['forrester.com', 'gartner.com', 'idc.com'];\n    if (analystDomains.some(an => domain === an || domain.endsWith('.' + an))) {\n      return { level: 2, label: 'Tertiary Source', rationale: 'Commercial research firm commentary' };\n    }\n\n    if (domain.endsWith('.org')) {\n      return { level: 2, label: 'Tertiary Source', rationale: `Organization domain: ${domain}` };\n    }\n\n    return { level: 3, label: 'Unclassified', rationale: `General web source: ${domain}. Veracity requires verification.` };\n  }\n\n  function buildCitationGraph(sources) {\n    const citation_map = {};\n    for (const s of sources) {\n      citation_map[s.id] = { cites: {} };\n    }\n    \n    const stopWords = new Set([\n      'a', 'an', 'the', 'is', 'of', 'in', 'to', 'for', 'and', 'or', 'with', 'on', 'at', 'by',\n      'from', 'as', 'into', 'through', 'during', 'before', 'after', 'above', 'below', 'between',\n      'under', 'again', 'further', 'then', 'once', 'here', 'there', 'when', 'where', 'why', 'how',\n      'all', 'both', 'each', 'few', 'more', 'most', 'other', 'some', 'such', 'no', 'nor', 'not', 'only',\n      'own', 'same', 'so', 'than', 'too', 'very', 'just', 'also', 'now', 'about', 'up', 'out', 'if'\n    ]);\n    \n    function extractKeywords(title) {\n      if (!title) return [];\n      return title.toLowerCase()\n        .split(/[^a-z0-9]+/)\n        .filter(w => w && w.length > 1 && !stopWords.has(w));\n    }\n    \n    for (const A of sources) {\n      if (!A.text) continue;\n      const aTextLower = A.text.toLowerCase();\n      \n      for (const B of sources) {\n        if (A.id === B.id) continue;\n        \n        const bCanonical = normalizeUrl(B.url);\n        const bDomain = safeDomain(B.url);\n        const bKeywords = extractKeywords(B.title);\n        \n        let citation_score = 0;\n        const matches = [];\n        \n        if (bCanonical && A.text.includes(bCanonical)) {\n          citation_score += 3;\n          matches.push('Direct URL citation');\n        }\n        \n        if (bDomain && bDomain !== 'unknown' && bDomain.length > 3 && aTextLower.includes(bDomain)) {\n          citation_score += 2;\n          matches.push(`Domain-level reference: ${bDomain}`);\n        }\n        \n        if (bKeywords && bKeywords.length >= 3) {\n          let matchedCount = 0;\n          for (const kw of bKeywords) {\n            if (aTextLower.includes(kw)) {\n              matchedCount++;\n            }\n          }\n          if (matchedCount / bKeywords.length >= 0.6) {\n            citation_score += 1;\n            matches.push(`Title keyword overlap (${matchedCount}/${bKeywords.length} keywords)`);\n          }\n        }\n        \n        if (citation_score >= 3) {\n          citation_map[A.id].cites[B.id] = {\n            score: citation_score,\n            evidence: matches.join('; ')\n          };\n        }\n      }\n    }\n    \n    const circular_chains = [];\n    const visitedCycles = new Set();\n    \n    function findCyclesDFS(nodeId, path, visited) {\n      const lastNode = path[path.length - 1];\n      const neighbors = Object.keys(citation_map[lastNode]?.cites || {}).map(Number);\n      \n      for (const neighbor of neighbors) {\n        const cycleStartIndex = path.indexOf(neighbor);\n        if (cycleStartIndex !== -1) {\n          const cycle = path.slice(cycleStartIndex);\n          cycle.push(neighbor);\n          \n          const cycleNodes = cycle.slice(0, -1);\n          const minVal = Math.min(...cycleNodes);\n          const minIdx = cycleNodes.indexOf(minVal);\n          const canonicalNodes = [...cycleNodes.slice(minIdx), ...cycleNodes.slice(0, minIdx)];\n          canonicalNodes.push(minVal);\n          \n          const key = canonicalNodes.join(',');\n          if (!visitedCycles.has(key)) {\n            visitedCycles.add(key);\n            const desc = canonicalNodes.map(id => `S${id}`).join('\u2192');\n            circular_chains.push({\n              chain: canonicalNodes,\n              description: desc\n            });\n          }\n        } else if (!visited.has(neighbor)) {\n          visited.add(neighbor);\n          findCyclesDFS(nodeId, [...path, neighbor], visited);\n          visited.delete(neighbor);\n        }\n      }\n    }\n    \n    for (const source of sources) {\n      const visited = new Set([source.id]);\n      findCyclesDFS(source.id, [source.id], visited);\n    }\n    \n    function canReach(startId, targetId) {\n      const queue = [startId];\n      const visited = new Set([startId]);\n      while (queue.length > 0) {\n        const current = queue.shift();\n        if (current === targetId) return true;\n        const neighbors = Object.keys(citation_map[current]?.cites || {}).map(Number);\n        for (const neighbor of neighbors) {\n          if (!visited.has(neighbor)) {\n            visited.add(neighbor);\n            queue.push(neighbor);\n          }\n        }\n      }\n      return false;\n    }\n    \n    const level0Sources = sources.filter(s => s.credibility_level === 0);\n    let single_primary = null;\n    \n    if (sources.length >= 3) {\n      for (const S0 of level0Sources) {\n        const dependents = [];\n        for (const S of sources) {\n          if (S.id === S0.id) continue;\n          if (S.credibility_level >= 1) {\n            if (canReach(S.id, S0.id)) {\n              dependents.push(S.id);\n            }\n          }\n        }\n        \n        if (dependents.length >= 3) {\n          single_primary = {\n            primary_source_id: S0.id,\n            primary_title: S0.title,\n            dependent_sources: dependents,\n            warning: `MULTIPLE_SOURCES_SINGLE_PRIMARY: Sources [${dependent