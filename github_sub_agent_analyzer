      "id": "get_full_file_func",
      "code": "async function get_full_file(params, userSettings) {\n  const { repoUrl, branch, filePath } = params;\n  const { githubPAT, maxLinesForFullFile, maxCharsPerLine } = userSettings;\n\n  try {\n    const match = repoUrl.match(/github\\.com\\/([^\\/]+)\\/([^\\/]+)/);\n    if (!match) return \"Error: Invalid GitHub URL.\";\n    const owner = match[1];\n    const repo = match[2].replace('.git', '');\n\n    let targetBranch = branch;\n    if (!targetBranch) {\n      const repoInfoRes = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {\n        headers: { 'Authorization': `Bearer ${githubPAT}` }\n      });\n      const repoInfo = await repoInfoRes.json();\n      targetBranch = repoInfo.default_branch;\n    }\n\n    const fileRes = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}?ref=${targetBranch}`, {\n      headers: { \n          'Authorization': `Bearer ${githubPAT}`,\n          'Accept': 'application/vnd.github.v3.raw'\n      }\n    });\n    \n    if (!fileRes.ok) return `Error fetching file: ${fileRes.statusText}`;\n    const fileContent = await fileRes.text();\n    \n    const lines = fileContent.split('\\n');\n    const maxLines = maxLinesForFullFile || 300;\n    const maxChars = maxCharsPerLine || 1000;\n\n    if (lines.length > maxLines) {\n      return `Request Rejected: The file ${filePath} contains ${lines.length} lines, which exceeds your safety limit of ${maxLines} lines.\\n\\nTo save tokens and context window, please use the 'analyze_files_with_flash_lite' tool to summarize it, or the 'fetch_code_by_anchor' tool to pull a specific section.`;\n    }\n\n    // Block files containing massive packed lines, single-line datasets, or minified code\n    for (let i = 0; i < lines.length; i++) {\n      if (lines[i].length > maxChars) {\n        return `Request Rejected: Line ${i + 1} in ${filePath} has a length of ${lines[i].length} characters, which exceeds your safety limit of ${maxChars} characters per line.\\n\\nThis typically indicates a minified file, a compiled asset, or an inline database/dataset. Fetching this directly will blow out context limits and lead to expensive API usage.\\n\\nRECOMMENDED ACTION: Do NOT read this file raw. Use 'analyze_files_with_flash_lite' to construct a structural summary, or ask the user to explain its schema/contents.`;\n      }\n    }\n\n    return `### Full File: ${filePath} (${lines.length} lines)\\n\\n\\`\\`\\`\\n${fileContent}\\n\\`\\`\\``;\n\n  } catch (err) {\n    return `Execution Error: ${err.message}`;\n  }\n}",
