      "id": "get_repo_structure_func",
      "code": "async function get_repo_structure(params, userSettings) {\n  const { repoUrl, branch } = params;\n  const { githubPAT } = userSettings;\n  try {\n    const match = repoUrl.match(/github\\.com\\/([^\\/]+)\\/([^\\/]+)/);\n    if (!match) return \"Error: Invalid GitHub URL. Must be in format https://github.com/owner/repo\";\n    const owner = match[1];\n    const repo = match[2].replace('.git', '');\n\n    let targetBranch = branch;\n    if (!targetBranch) {\n      const repoInfoRes = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {\n        headers: { 'Authorization': `Bearer ${githubPAT}` }\n      });\n      if (!repoInfoRes.ok) return `Error fetching repo info: ${repoInfoRes.statusText}`;\n      const repoInfo = await repoInfoRes.json();\n      targetBranch = repoInfo.default_branch;\n    }\n\n    const treeRes = await fetch(`https://api.github.com/repos/${owner}/${repo}/git/trees/${targetBranch}?recursive=1`, {\n      headers: { 'Authorization': `Bearer ${githubPAT}` }\n    });\n    if (!treeRes.ok) return `Error fetching tree: ${treeRes.statusText}`;\n    \n    const treeData = await treeRes.json();\n    if (treeData.truncated) return \"Warning: Tree truncated because it is too large. Results may be incomplete.\\n\\n\" + formatTree(treeData.tree);\n    return formatTree(treeData.tree);\n\n  } catch (err) {\n    return `Execution Error: ${err.message}`;\n  }\n\n  function formatTree(treeItems) {\n    const ignoreList = ['node_modules', '.git', 'package-lock.json', 'yarn.lock', 'dist', 'build', '.next', '__pycache__'];\n    const paths = treeItems\n      .map(item => item.path)\n      .filter(path => !ignoreList.some(ignore => path.includes(ignore) || path.startsWith(ignore)));\n    return \"Repository File Structure:\\n\" + paths.join('\\n');\n  }\n}",
