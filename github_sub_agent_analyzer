      "id": "analyze_files_with_flash_func",
      "code": "async function analyze_files_with_flash_lite(params, userSettings) {\n  const { repoUrl, branch, filePaths } = params;\n  const { githubPAT, geminiAPIKey, geminiModel } = userSettings;\n  \n  if (filePaths.length > 7) return \"Error: You can only analyze up to 7 files at a time to prevent context overflow.\";\n\n  try {\n    const match = repoUrl.match(/github\\.com\\/([^\\/]+)\\/([^\\/]+)/);\n    if (!match) return \"Error: Invalid GitHub URL.\";\n    const owner = match[1];\n    const repo = match[2].replace('.git', '');\n\n    let targetBranch = branch;\n    if (!targetBranch) {\n      const repoInfoRes = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {\n        headers: { 'Authorization': `Bearer ${githubPAT}` }\n      });\n      const repoInfo = await repoInfoRes.json();\n      targetBranch = repoInfo.default_branch;\n    }\n\n    const systemPrompt = \"You are an expert architecture mapping agent. Your task is to process this raw code file and output a dense, hierarchical Natural Language (NL) representation of its structural components.\\n\\nIgnore granular syntax, variables, and standard boilerplate. Focus strictly on:\\n1. External dependencies and library orchestration.\\n2. Class and Method definitions.\\n3. The Big-Picture business logic of what each section achieves.\\n\\n**FORMATTING RULES:**\\nDo NOT use line numbers. For every class or primary function, provide a `[SEARCH ANCHOR]` containing the exact, literal string of the definition exactly as written in the code (e.g., `export const fetchUserData = async () =>` or `def process_data(self):`).\\nKeep descriptions extremely dense. Use bullet points. Prioritize data flow.\";\n\n    let finalOutput = \"### Sub-Agent Flash Lite Analysis Report\\n\\n\";\n\n    // Process sequentially to avoid Gemini free-tier rate limits\n    for (const path of filePaths) {\n      const fileRes = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${path}?ref=${targetBranch}`, {\n        headers: { \n            'Authorization': `Bearer ${githubPAT}`,\n            'Accept': 'application/vnd.github.v3.raw'\n        }\n      });\n      \n      if (!fileRes.ok) {\n        finalOutput += `\\n---\\n**File:** ${path}\\n*Error fetching file: ${fileRes.statusText}*\\n`;\n        continue;\n      }\n      \n      const fileContent = await fileRes.text();\n      \n      const geminiBody = {\n        contents: [{\n          parts: [{ text: `FILE PATH: ${path}\\n\\nCODE CONTENT:\\n${fileContent}` }]\n        }],\n        systemInstruction: { parts: [{ text: systemPrompt }] }\n      };\n\n      const geminiRes = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${geminiModel || 'gemini-2.5-flash'}:generateContent?key=${geminiAPIKey}`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(geminiBody)\n      });\n\n      if (!geminiRes.ok) {\n        finalOutput += `\\n---\\n**File:** ${path}\\n*Error from Gemini API: ${geminiRes.statusText}*\\n`;\n        continue;\n      }\n\n      const geminiData = await geminiRes.json();\n      const analysis = geminiData.candidates?.[0]?.content?.parts?.[0]?.text || \"No content generated.\";\n      \n      finalOutput += `\\n---\\n**File:** ${path}\\n${analysis}\\n`;\n    }\n\n    return finalOutput;\n\n  } catch (err) { \n    return `Execution Error: ${err.message}`;\n  }\n}",
