      "id": "fetch_code_by_anchor_func",
      "code": "async function fetch_code_by_anchor(params, userSettings) {\n  const { repoUrl, branch, filePath, anchorString, linesAfter = 50 } = params;\n  const { githubPAT, maxCharsPerLine } = userSettings;\n\n  try {\n    const match = repoUrl.match(/github\\.com\\/([^\\/]+)\\/([^\\/]+)/);\n    if (!match) return \"Error: Invalid GitHub URL.\";\n    const owner = match[1];\n    const repo = match[2].replace('.git', '');\n\n    let targetBranch = branch;\n    if (!targetBranch) {\n      const repoInfoRes = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {\n        headers: { 'Authorization': `Bearer ${githubPAT}` }\n      });\n      const repoInfo = await repoInfoRes.json();\n      targetBranch = repoInfo.default_branch;\n    }\n\n    const fileRes = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}?ref=${targetBranch}`, {\n      headers: { \n          'Authorization': `Bearer ${githubPAT}`,\n          'Accept': 'application/vnd.github.v3.raw'\n      }\n    });\n    \n    if (!fileRes.ok) return `Error fetching file: ${fileRes.statusText}`;\n    const fileContent = await fileRes.text();\n    const lines = fileContent.split('\\n');\n\n    let anchorIndex = -1;\n    // Try exact match first\n    anchorIndex = lines.findIndex(line => line.includes(anchorString));\n    \n    // If not found, try a fuzzy match (lowercase, stripped whitespace)\n    if (anchorIndex === -1) {\n      const cleanAnchor = anchorString.toLowerCase().replace(/\\s+/g, '');\n      anchorIndex = lines.findIndex(line => line.toLowerCase().replace(/\\s+/g, '').includes(cleanAnchor));\n    }\n\n    if (anchorIndex === -1) {\n      return `Error: Could not find the anchor string \"${anchorString}\" in ${filePath}. The Flash Lite model may have hallucinated it, or it contains irregular formatting. Please try fetching the full file (if small enough) or use a shorter, more specific sub-string as your anchor.`;\n    }\n\n    const endIndex = Math.min(lines.length, anchorIndex + linesAfter + 1);\n    const codeLines = lines.slice(anchorIndex, endIndex);\n    const maxChars = maxCharsPerLine || 1000;\n\n    // Stop models from extracting minified files or giant datasets via anchors\n    for (let i = 0; i < codeLines.length; i++) {\n      if (codeLines[i].length > maxChars) {\n        return `Request Rejected: Line ${anchorIndex + i + 1} in the requested snippet has a length of ${codeLines[i].length} characters, which exceeds your safety limit of ${maxChars} characters per line.\\n\\nThis snippet contains minified, compiled, or extremely long unformatted code. Fetching it raw would cause massive token costs and rate limit exceptions.\\n\\nRECOMMENDED ACTION: Do NOT retrieve raw syntax for this file. Use 'analyze_files_with_flash_lite' to inspect it structurally or ask the user for details.`;\n      }\n    }\n\n    const codeSnippet = codeLines.join('\\n');\n    return `### Code Snippet from ${filePath} (Lines ${anchorIndex + 1} to ${endIndex})\\n\\n\\`\\`\\`\\n${codeSnippet}\\n\\`\\`\\``;\n\n  } catch (err) {\n    return `Execution Error: ${err.message}`;\n  }\n}",
