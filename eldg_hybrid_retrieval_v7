      "code": "async function eldg_hybrid_retrieval_v7(params, userSettings) {\n  const { query, contextMetadata, outputIntent, detailMode } = params;\n  const proxyBase = (userSettings.workerUrl || 'https://unified-proxy.creativeappmaking.workers.dev').replace(/\\/$/, '');\n  const geminiApiKey = userSettings.google_api_key;\n  const exaApiKey = userSettings.exa_api_key;\n  const geminiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite:generateContent?key=${geminiApiKey}`;\n  const exaProxyUrl = `${proxyBase}/exa/search`;\n  const exaDirectUrl = 'https://api.exa.ai/search';\n  const today = new Date().toISOString().split('T')[0];\n  const currentYear = today.split('-')[0];\n  let transportState = 'healthy';\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  function clamp(num, min, max) {\n    return Math.max(min, Math.min(max, num));\n  }\n\n  function unique(arr) {\n    return Array.from(new Set((arr || []).filter(Boolean)));\n  }\n\n  function toArray(v) {\n    return Array.isArray(v) ? v.filter(Boolean) : [];\n  }\n\n  function truncate(text, max) {\n    if (!text) return '';\n    return text.length <= max ? text : text.slice(0, max);\n  }\n\n  function normalizeUrl(url) {\n    try {\n      const u = new URL(url);\n      u.hash = '';\n      u.search = '';\n      return u.toString().replace(/\\/$/, '');\n    } catch (e) {\n      return url || '';\n    }\n  }\n\n  function safeDomain(url) {\n    try {\n      return new URL(url).hostname.replace(/^www\\./, '');\n    } catch (e) {\n      return 'unknown';\n    }\n  }\n\n  function cleanTextPreserveLines(text) {\n    if (!text) return '';\n    return String(text)\n      .replace(/\\r/g, '\\n')\n      .replace(/\\u0000/g, '')\n      .replace(/\\t/g, '  ')\n      .replace(/[ \\u00A0]+\\n/g, '\\n')\n      .replace(/\\n{3,}/g, '\\n\\n')\n      .trim();\n  }\n\n  function lineLooksCode(line) {\n    if (!line) return false;\n    const trimmed = line.trim();\n    if (!trimmed) return false;\n    if (/^(import |export |const |let |var |function |async function |class |interface |type |enum |SELECT |INSERT |UPDATE |DELETE |CREATE |ALTER |curl |npm |pnpm |yarn |docker |kubectl |terraform |resource |module |FROM |WHERE )/i.test(trimmed)) return true;\n    if (/=>|\\{\\s*$|^\\}|;\\s*$|<\\/?[A-Za-z]|Response\\.json|NextResponse|await |return |console\\.|^\\s{2,}[A-Za-z0-9_$]/.test(line)) return true;\n    return false;\n  }\n\n  function lineLooksList(line) {\n    if (!line) return false;\n    const trimmed = line.trim();\n    return /^([-*•]|\\d+[.)]|[A-Za-z]\\.)\\s+/.test(trimmed);\n  }\n\n  function lineLooksLegal(line) {\n    if (!line) return false;\n    return /\\b(section|article|clause|statute|regulation|subsection|paragraph|shall|pursuant|effective date|whereas|hereby|means)\\b/i.test(line);\n  }\n\n  function tokenizeNeedles(routePlan) {\n    const terms = [];\n    terms.push(...toArray(routePlan.key_terms));\n    const depNames = Object.keys((contextMetadata && contextMetadata.dependencyManifest) || {});\n    terms.push(...depNames);\n    const q = String(query || '').split(/[^A-Za-z0-9_.#:-]+/).filter(t => t && t.length > 2);\n    terms.push(...q.slice(0, 16));\n    return unique(terms.map(t => String(t).trim()).filter(t => t.length > 1)).slice(0, 24);\n  }\n\n  function countKeywordHits(text, terms) {\n    if (!text) return 0;\n    const lower = text.toLowerCase();\n    let score = 0;\n    for (const term of terms) {\n      const t = String(term).toLowerCase();\n      if (!t) continue;\n      if (lower.includes(t)) score += Math.min(3, lower.split(t).length - 1);\n    }\n    return score;\n  }\n\n  function chunkText(text, targetSize) {\n    const cleaned = cleanTextPreserveLines(text);\n    if (!cleaned) return [];\n    const paragraphs = cleaned.split(/\\n\\s*\\n/).filter(Boolean);\n    if (paragraphs.length === 0) return [cleaned.slice(0, targetSize)];\n\n    const chunks = [];\n    let current = '';\n    for (const para of paragraphs) {\n      const candidate = current ? `${current}\\n\\n${para}` : para;\n      if (candidate.length <= targetSize) {\n        current = candidate;\n      } else {\n        if (current) chunks.push(current);\n        if (para.length <= targetSize) {\n          current = para;\n        } else {\n          for (let i = 0; i < para.length; i += targetSize) {\n            chunks.push(para.slice(i, i + targetSize));\n          }\n          current = '';\n        }\n      }\n    }\n    if (current) chunks.push(current);\n    return chunks;\n  }\n\n  function scoreChunk(chunk, routePlan, searchBranch) {\n    const terms = tokenizeNeedles(routePlan);\n    const lines = chunk.split('\\n');\n    const codeLines = lines.filter(lineLooksCode).length;\n    const listLines = lines.filter(lineLooksList).length;\n    const legalLines = lines.filter(lineLooksLegal).length;\n    const keywordHits = countKeywordHits(chunk, terms);\n    const lower = chunk.toLowerCase();\n    const boundaryHits = (lower.match(/\\b(but|except|unless|however|warning|caveat|limitation|issue|deprecated|broken|note)\\b/g) || []).length;\n    let score = keywordHits * 3 + boundaryHits;\n\n    if (routePlan.need_class === 'code_extract') score += codeLines * 4 + listLines;\n    if (routePlan.need_class === 'enumeration_extract' || routePlan.need_class === 'procedure_extract') score += listLines * 4 + codeLines;\n    if (routePlan.need_class === 'verbatim_extract' || outputIntent === 'VERBATIM_STATUTE') score += legalLines * 4;\n    if (routePlan.need_class === 'version_pin' || routePlan.need_class === 'contradiction_audit') score += boundaryHits * 2;\n    if (searchBranch === 'adversarial') score += 1;\n    return score;\n  }\n\n  function selectWindowsForSource(source, routePlan, budgetChars) {\n    const targetChunk = routePlan.need_class === 'code_extract' ? 1400 : routePlan.breadth_mode === 'exhaustive' ? 1200 : 900;\n    const chunks = chunkText(source.text || '', targetChunk);\n    if (chunks.length === 0) return [];\n\n    const scored = chunks.map((chunk, idx) => ({\n      idx,\n      text: chunk,\n      score: scoreChunk(chunk, routePlan, source.branch),\n      codeLines: chunk.split('\\n').filter(lineLooksCode).length,\n      listLines: chunk.split('\\n').filter(lineLooksList).length,\n      legalLines: chunk.split('\\n').filter(lineLooksLegal).length,\n    }));\n\n    scored.sort((a, b) => b.score - a.score || a.idx - b.idx);\n\n    const maxWindows = routePlan.breadth_mode === 'exhaustive' ? 3 : 2;\n    const chosen = [];\n    let spent = 0;\n    const usedIdx = new Set();\n\n    for (const candidate of scored) {\n      if (chosen.length >= maxWindows) break;\n      if (spent >= budgetChars) break;\n      if (usedIdx.has(candidate.idx)) continue;\n      const remaining = budgetChars - spent;\n      const pickedText = truncate(candidate.text, remaining);\n      if (!pickedText) continue;\n\n      let kind = 'context';\n      if (routePlan.need_class === 'code_extract' && candidate.codeLines >= 2) kind = 'code';\n      else if ((routePlan.need_class === 'enumeration_extract' || routePlan.need_class === 'procedure_extract') && candidate.listLines >= 2) kind = 'list';\n      else if ((routePlan.need_class === 'verbatim_extract' || outputIntent === 'VERBATIM_STATUTE') && candidate.legalLines >= 1) kind = 'verbatim';\n      else if ((source.branch === 'adversarial') || /\\b(but|except|unless|however|warning|caveat|limitation|issue|deprecated|broken|note)\\b/i.test(candidate.text)) kind = 'boundary';\n      else kind = 'support';\n\n      chosen.push({ sourceId: source.id, kind, text: pickedText });\n      usedIdx.add(candidate.idx);\n      spent += pickedText.length;\n    }\n\n    if (chosen.length === 0) {\n      chosen.push({ sourceId: source.id, kind: 'support', text: truncate(source.text || '', budgetChars) });\n    }\n\n    return chosen;\n  }\n\n  function classifySourceRole(url, title) {\n    const domain = safeDomain(url);\n    const titleLower = String(title || '').toLowerCase();\n    if (/github\\.com$/.test(domain)) return 'github';\n    if (/docs|developer|developers|reference|manual|api/.test(domain) || /documentation|reference|api/i.test(titleLower)) return 'official_docs';\n    if (/wikipedia\\.org$/.test(domain)) return 'encyclopedia';\n    if (/reddit\\.com$/.test(domain)) return 'forum';\n    return 'web';\n  }\n\n  function makeFallbackRoutePlan() {\n    const q = String(query || '').toLowerCase();\n    let needClass = 'fact_pin';\n    let breadthMode = 'standard';\n    let exactnessMode = 'summary_safe';\n    let searchMode = 'single';\n    const codeLike = outputIntent === 'CODE_BOILERPLATE' || /\\b(code|snippet|function|class|interface|type|schema|sql|regex|implementation|route handler|api route|curl|command|config)\\b/.test(q);\n    const verbatimLike = outputIntent === 'VERBATIM_STATUTE' || /\\b(verbatim|exact text|exact quote|quote|clause|section|article|statute|law|regulation)\\b/.test(q);\n    const listLike = /\\b(list all|full list|enumerate|every |exact option|allowed values|all flags|all params|all properties|all methods)\\b/.test(q);\n    const procedureLike = /\\b(step by step|steps|procedure|migration steps|how do i|how to)\\b/.test(q);\n    const adversarialLike = /\\b(compare|vs\\b|versus|tradeoff|better|worse|pros and cons|limitations|criticism|broken|bug|deprecated|issue|compatible|current|latest|support|supported)\\b/.test(q);\n\n    if (codeLike) {\n      needClass = 'code_extract';\n      breadthMode = 'exhaustive';\n      exactnessMode = 'raw_code';\n    } else if (verbatimLike) {\n      needClass = 'verbatim_extract';\n      breadthMode = 'exhaustive';\n      exactnessMode = 'exact_spans';\n    } else if (listLike) {\n      needClass = 'enumeration_extract';\n      breadthMode = 'exhaustive';\n      exactnessMode = 'exact_spans';\n    } else if (procedureLike) {\n      needClass = 'procedure_extract';\n      breadthMode = 'exhaustive';\n      exactnessMode = 'exact_spans';\n    } else if (/\\b(compare|vs\\b|versus|tradeoff|better|worse|pros and cons)\\b/.test(q)) {\n      needClass = 'tradeoff_map';\n      searchMode = 'dual';\n    } else if (adversarialLike) {\n      needClass = 'version_pin';\n      searchMode = 'dual';\n    }\n\n    if (detailMode === 'MINIMAL') breadthMode = 'scalar';\n    if (detailMode === 'EXHAUSTIVE' || detailMode === 'RAW_TEXT') breadthMode = 'exhaustive';\n    if (detailMode === 'RAW_TEXT' && exactnessMode === 'summary_safe') exactnessMode = 'exact_spans';\n\n    return {\n      need_class: needClass,\n      breadth_mode: breadthMode,\n      exactness_mode: exactnessMode,\n      search_mode: searchMode,\n      primary_query: `The official, relevant, and current details for ${query} are`,\n      adversarial_query: searchMode === 'dual' ? `The limitations, contradictions, caveats, failure cases, and counter-evidence for ${query} are` : null,\n      key_terms: tokenizeNeedles({ key_terms: [], need_class: needClass, breadth_mode: breadthMode }),\n      include_domains: [],\n      exclude_domains: ['pinterest.com'],\n      primary_results: breadthMode === 'exhaustive' ? 6 : 4,\n      adversarial_results: searchMode === 'dual' ? 4 : 0,\n      notes: []\n    };\n  }\n\n  async function callGemini(systemInstruction, userPrompt, responseSchema, maxOutputTokens) {\n    const payload = {\n      contents: [{ parts: [{ text: userPrompt }] }],\n      systemInstruction: { parts: [{ text: systemInstruction }] },\n      generationConfig: {\n        maxOutputTokens: maxOutputTokens || 4096\n      }\n    };\n    if (responseSchema) {\n      payload.generationConfig.responseMimeType = 'application/json';\n      payload.generationConfig.responseSchema = responseSchema;\n    }\n\n    for (let attempt = 0; attempt < 3; attempt++) {\n      try {\n        const res = await fetch(geminiUrl, {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify(payload)\n        });\n        if (res.ok) {\n          const data = await res.json();\n          return data.candidates?.[0]?.content?.parts?.[0]?.text || null;\n        }\n        if (res.status === 429 || res.status >= 500) {\n          await sleep((attempt + 1) * 1000);\n          continue;\n        }\n      } catch (e) {\n        if (attempt === 2) return null;\n        await sleep((attempt + 1) * 1000);\n      }\n    }\n    return null;\n  }\n\n  const routerSystem = `You are the Volatility-Aware Need Router for Exa-ELDG Hybrid v7.0. Today is ${today}.\\nClassify the user's retrieval need so the parent LLM does not need multiple nearly-identical tool calls.\\n\\nPRIMARY OBJECTIVE:\\nChoose the retrieval mode that returns exactly the kind of material the parent model actually needs. Some tasks require claims; others require exact artifacts.\\n\\nNEED CLASSES:\\n- fact_pin: small scalar fact or single grounded answer.\\n- version_pin: current behavior/status/version-sensitive answer with checks and balances.\\n- tradeoff_map: compare alternatives and surface trade-offs/counter-evidence.\\n- contradiction_audit: aggressively surface disagreement, caveats, stale docs, and runtime divergence.\\n- code_extract: return raw code/config/signatures/commands exactly as found, not descriptions of code.\\n- verbatim_extract: return exact quoted/verbatim text, clauses, or excerpts.\\n- enumeration_extract: return exhaustive item-by-item extraction for options, methods, flags, rows, properties, lists, or headings.\\n- procedure_extract: return step-by-step procedures, migrations, or instructions as extracted items.\\n\\nRULES:\\n1. Use outputIntent and the user query together. If the user asks for code, exact text, clauses, options, or all items, DO NOT classify as fact_pin.\\n2. Suppress adversarial search only when the task is truly stable and scalar.\\n3. For code_extract and exact-text modes, prefer official docs and GitHub; for legal text prefer official/legal domains; for empirical/news items allow adversarial search when instability exists.\\n4. Return up to 12 key terms that help local client-side window selection.\\n5. Use declarative completion-style search queries, not questions.\\n6. Respect detailMode: MINIMAL lowers breadth; EXHAUSTIVE increases breadth; RAW_TEXT implies exactness_mode != summary_safe.`;\n\n  const routerSchema = {\n    type: 'OBJECT',\n    properties: {\n      need_class: { type: 'STRING', enum: ['fact_pin', 'version_pin', 'tradeoff_map', 'contradiction_audit', 'code_extract', 'verbatim_extract', 'enumeration_extract', 'procedure_extract'] },\n      breadth_mode: { type: 'STRING', enum: ['scalar', 'standard', 'exhaustive'] },\n      exactness_mode: { type: 'STRING', enum: ['summary_safe', 'exact_spans', 'raw_code'] },\n      search_mode: { type: 'STRING', enum: ['single', 'dual'] },\n      primary_query: { type: 'STRING' },\n      adversarial_query: { type: 'STRING' },\n      key_terms: { type: 'ARRAY', items: { type: 'STRING' } },\n      include_domains: { type: 'ARRAY', items: { type: 'STRING' } },\n      exclude_domains: { type: 'ARRAY', items: { type: 'STRING' } },\n      primary_results: { type: 'INTEGER' },\n      adversarial_results: { type: 'INTEGER' },\n      notes: { type: 'ARRAY', items: { type: 'STRING' } }\n    },\n    required: ['need_class', 'breadth_mode', 'exactness_mode', 'search_mode', 'primary_query', 'adversarial_query', 'key_terms', 'include_domains', 'exclude_domains', 'primary_results', 'adversarial_results', 'notes']\n  };\n\n  const routerPrompt = `User Query: \"${query}\"\\nOutput Intent: ${outputIntent || 'DEFAULT'}\\nDetail Mode: ${detailMode || 'AUTO'}\\nContext Metadata: ${JSON.stringify(contextMetadata || {})}`;\n\n  let routePlanText = await callGemini(routerSystem, routerPrompt, routerSchema, 1536);\n  let routePlan = null;\n  try {\n    routePlan = JSON.parse(routePlanText);\n  } catch (e) {\n    routePlan = makeFallbackRoutePlan();\n  }\n\n  if (detailMode === 'MINIMAL') routePlan.breadth_mode = 'scalar';\n  if (detailMode === 'EXHAUSTIVE' || detailMode === 'RAW_TEXT') routePlan.breadth_mode = 'exhaustive';\n  if (detailMode === 'RAW_TEXT' && routePlan.exactness_mode === 'summary_safe') routePlan.exactness_mode = outputIntent === 'CODE_BOILERPLATE' ? 'raw_code' : 'exact_spans';\n\n  async function attemptExa(endpointUrl, body) {\n    const response = await fetch(endpointUrl, {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'x-api-key': exaApiKey\n      },\n      body: JSON.stringify(body)\n    });\n    if (!response.ok) throw new Error(`HTTP_${response.status}`);\n    const data = await response.json();\n    return data.results || [];\n  }\n\n  async function runExa(branch, searchQuery, numResults) {\n    if (!searchQuery) {\n      return { branch, status: 'skipped', via: null, results: [], error: null };\n    }\n\n    const maxCharacters = routePlan.need_class === 'code_extract'\n      ? 12000\n      : routePlan.breadth_mode === 'exhaustive'\n      ? 9000\n      : routePlan.need_class === 'fact_pin'\n      ? 4500\n      : 6500;\n\n    const body = {\n      query: searchQuery,\n      numResults: clamp(numResults || 4, 1, 8),\n      type: 'auto',\n      contents: {\n        text: { maxCharacters },\n        highlights: {\n          numSentences: routePlan.need_class === 'fact_pin' ? 2 : 4,\n          highlightsPerUrl: 2\n        }\n      }\n    };\n\n    const includeDomains = toArray(routePlan.include_domains);\n    const excludeDomains = toArray(routePlan.exclude_domains);\n    if (includeDomains.length) body.includeDomains = includeDomains;\n    if (excludeDomains.length) body.excludeDomains = excludeDomains;\n\n    const endpoints = [];\n    if (proxyBase) endpoints.push({ url: exaProxyUrl, via: 'proxy' });\n    endpoints.push({ url: exaDirectUrl, via: 'direct' });\n\n    const errors = [];\n    for (const endpoint of endpoints) {\n      try {\n        const results = await attemptExa(endpoint.url, body);\n        if (endpoint.via === 'direct') transportState = transportState === 'healthy' ? 'degraded' : transportState;\n        return { branch, status: 'success', via: endpoint.via, results, error: null };\n      } catch (e) {\n        errors.push(`${endpoint.via}:${e.message}`);\n      }\n    }\n\n    if (errors.every(err => /TypeError|Failed to fetch|fetch/i.test(err) || /proxy:HTTP_5|direct:HTTP_4/.test(err))) {\n      transportState = transportState === 'healthy' ? 'degraded' : transportState;\n    }\n\n    return { branch, status: 'failed', via: null, results: [], error: errors.join('; ') || 'unknown_error' };\n  }\n\n  const branchRuns = await Promise.all([\n    runExa('primary', routePlan.primary_query, routePlan.primary_results),\n    routePlan.search_mode === 'dual' ? runExa('adversarial', routePlan.adversarial_query, routePlan.adversarial_results) : Promise.resolve({ branch: 'adversarial', status: 'skipped', via: null, results: [], error: null })\n  ]);\n\n  const branchStatuses = branchRuns.map(run => ({ branch: run.branch, status: run.status, via: run.via, error: run.error }));\n\n  const allResults = [];\n  branchRuns.forEach(run => {\n    (run.results || []).forEach(r => {\n      allResults.push({ ...r, branch: run.branch });\n    });\n  });\n\n  if (allResults.length === 0) {\n    const partitioned = branchRuns.every(run => run.status !== 'success');\n    return {\n      completion_state: partitioned ? 'partitioned' : 'degraded',\n      transport_state: partitioned ? 'partitioned' : transportState,\n      failed_stage: 'retrieval_empty',\n      retrieval_state: {\n        search_mode: routePlan.search_mode,\n        branch_statuses: branchStatuses,\n        missing_axes: routePlan.search_mode === 'dual' ? ['primary_or_adversarial_missing'] : ['primary_missing']\n      },\n      error_diagnostic: 'No retrievable Exa results were returned from any active branch.',\n      degraded_manifest: { sources: [], evidence_lattice: [] }\n    };\n  }\n\n  const byUrl = new Map();\n  for (const r of allResults) {\n    const url = normalizeUrl(r.url);\n    if (!url) continue;\n    const domain = safeDomain(url);\n    const existing = byUrl.get(url);\n    const score = typeof r.score === 'number' ? r.score : 0;\n    if (!existing || score > (existing.score || 0)) {\n      byUrl.set(url, {\n        url,\n        title: r.title || domain,\n        domain,\n        branch: r.branch,\n        text: cleanTextPreserveLines(r.text || ''),\n        highlights: toArray(r.highlights),\n        publishedDate: r.publishedDate || null,\n        score,\n        role: classifySourceRole(url, r.title)\n      });\n    }\n  }\n\n  const branchQuotas = (() => {\n    if (routePlan.search_mode !== 'dual') return { primary: routePlan.breadth_mode === 'exhaustive' ? 8 : 6, adversarial: 0 };\n    if (routePlan.need_class === 'contradiction_audit') return { primary: 3, adversarial: 3 };\n    if (routePlan.need_class === 'tradeoff_map') return { primary: 3, adversarial: 3 };\n    if (routePlan.need_class === 'version_pin') return { primary: 4, adversarial: 2 };\n    return { primary: 4, adversarial: 2 };\n  })();\n\n  const resultsByBranch = { primary: [], adversarial: [] };\n  Array.from(byUrl.values()).forEach(item => {\n    resultsByBranch[item.branch] = resultsByBranch[item.branch] || [];\n    resultsByBranch[item.branch].push(item);\n  });\n\n  Object.keys(resultsByBranch).forEach(branch => {\n    resultsByBranch[branch].sort((a, b) => (b.score || 0) - (a.score || 0));\n  });\n\n  const finalSources = [];\n  const domainCaps = {};\n\n  function takeFromBranch(branch, limit) {\n    const list = resultsByBranch[branch] || [];\n    for (const item of list) {\n      if (finalSources.length >= 8) break;\n      domainCaps[item.domain] = domainCaps[item.domain] || 0;\n      if (domainCaps[item.domain] >= 2) continue;\n      if (finalSources.some(s => s.url === item.url)) continue;\n      finalSources.push(item);\n      domainCaps[item.domain] += 1;\n      if (finalSources.filter(s => s.branch === branch).length >= limit) break;\n    }\n  }\n\n  takeFromBranch('primary', branchQuotas.primary);\n  takeFromBranch('adversarial', branchQuotas.adversarial);\n\n  if (finalSources.length === 0) {\n    finalSources.push(...Array.from(byUrl.values()).slice(0, 6));\n  }\n\n  const totalContextChars = routePlan.need_class === 'code_extract'\n    ? 24000\n    : routePlan.breadth_mode === 'exhaustive'\n    ? 22000\n    : routePlan.need_class === 'fact_pin'\n    ? 9000\n    : 15000;\n\n  const dual = routePlan.search_mode === 'dual';\n  let primaryRatio = 1;\n  let adversarialRatio = 0;\n  if (dual) {\n    if (routePlan.need_class === 'contradiction_audit') {\n      primaryRatio = 0.45;\n      adversarialRatio = 0.55;\n    } else if (routePlan.need_class === 'tradeoff_map') {\n      primaryRatio = 0.5;\n      adversarialRatio = 0.5;\n    } else if (routePlan.need_class === 'version_pin') {\n      primaryRatio = 0.6;\n      adversarialRatio = 0.4;\n    } else {\n      primaryRatio = 0.7;\n      adversarialRatio = 0.3;\n    }\n  }\n\n  const perBranchBudget = {\n    primary: Math.floor(totalContextChars * primaryRatio),\n    adversarial: Math.floor(totalContextChars * adversarialRatio)\n  };\n\n  const sourceObjects = finalSources.map((source, idx) => ({\n    id: idx + 1,\n    title: source.title,\n    url: source.url,\n    domain: source.domain,\n    branch: source.branch,\n    role: source.role,\n    publishedDate: source.publishedDate,\n    text: source.text,\n    highlights: source.highlights\n  }));\n\n  const evidenceLattice = [];\n  const branchMissingAxes = [];\n  if (routePlan.search_mode === 'dual') {\n    if (!sourceObjects.some(s => s.branch === 'primary')) branchMissingAxes.push('supporting_evidence_under_sampled');\n    if (!sourceObjects.some(s => s.branch === 'adversarial')) branchMissingAxes.push('counterevidence_under_sampled');\n  }\n\n  const sourcesByBranch = {\n    primary: sourceObjects.filter(s => s.branch === 'primary'),\n    adversarial: sourceObjects.filter(s => s.branch === 'adversarial')\n  };\n\n  ['primary', 'adversarial'].forEach(branch => {\n    const branchSources = sourcesByBranch[branch] || [];\n    if (branchSources.length === 0) return;\n    const branchBudget = branch === 'primary' ? perBranchBudget.primary : perBranchBudget.adversarial;\n    const perSourceBudget = clamp(Math.floor(branchBudget / branchSources.length), routePlan.need_class === 'fact_pin' ? 700 : 1000, routePlan.need_class === 'code_extract' ? 3200 : 2600);\n    branchSources.forEach(source => {\n      const windows = selectWindowsForSource(source, routePlan, perSourceBudget);\n      windows.forEach(w => evidenceLattice.push(w));\n    });\n  });\n\n  if (evidenceLattice.length === 0) {\n    sourceObjects.forEach(source => {\n      evidenceLattice.push({ sourceId: source.id, kind: 'support', text: truncate(source.text || '', 1500) });\n    });\n  }\n\n  const ucsSystem = `TEMPORAL GROUNDING MANDATE: Today is ${today}. Current year is ${currentYear}. You are operating in real time.\\nYou are the Unified Context Sieve for Exa-ELDG Hybrid v7.0. The parent model needs enough breadth on the first call, not repeated near-duplicate calls.\\n\\nRETRIEVAL POLICY:\\n1. Use the Control Layer for grounded decision guidance, not conversational prose.\\n2. Use artifact extraction when the query asks for exact code, verbatim text, full lists, or step-by-step material.\\n3. If artifact text is returned inside artifacts.exactText, copy it directly from the provided lattice text. Do not paraphrase inside exactText. Preserve line breaks whenever present.\\n4. When the query asks for exhaustive options, methods, steps, or rows, enumerate them item-by-item in structured_items.\\n5. Keep claims for reconciled facts, conflicts, caveats, and version-sensitive conclusions.\\n6. Never invent code or exact text that is not directly present in the evidence lattice. If the available so