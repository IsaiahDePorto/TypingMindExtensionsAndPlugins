      "code": "async function perplexity_search(params, userSettings) {\n  const max_results_val = parseInt(params.max_results) || 10;\n  const max_tokens_val = parseInt(userSettings.max_tokens) || 25000;\n  const max_tokens_per_page_val = Math.floor(max_tokens_val / Math.max(1, max_results_val));\n\n  const payload = {\n    query: params.query,\n    max_results: max_results_val,\n    max_tokens: max_tokens_val,\n    max_tokens_per_page: max_tokens_per_page_val\n  };\n\n  const optionalParams = [\n    'country', 'search_language_filter', 'search_domain_filter', \n    'last_updated_after_filter', 'last_updated_before_filter', \n    'search_after_date_filter', 'search_before_date_filter', \n    'search_recency_filter'\n  ];\n\n  for (const p of optionalParams) {\n    if (params[p] !== undefined) {\n      payload[p] = params[p];\n    }\n  }\n\n  const response = await fetch(userSettings.worker_url, {\n    method: 'POST',\n    headers: {\n      'Authorization': 'Bearer ' + userSettings.perplexity_api_key,\n      'Content-Type': 'application/json'\n    },\n    body: JSON.stringify(payload)\n  });\n  \n  if (!response.ok) {\n    const err = await response.text();\n    throw new Error(`Worker Error: ${response.status} - ${err}`);\n  }\n  \n  return await response.json();\n}",
